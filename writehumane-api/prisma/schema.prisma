generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Every WordPress user who uses the humanizer across ANY site
model User {
  id              String    @id @default(cuid())
  email           String
  displayName     String?
  wpUserId        Int?
  wpRole          String?
  siteUrl         String    // Which WordPress site they're on
  firstSeenAt     DateTime  @default(now())
  lastActiveAt    DateTime  @default(now())
  totalWords      Int       @default(0)
  totalRequests   Int       @default(0)
  wordsThisMonth  Int       @default(0)
  monthResetAt    DateTime  @default(now())
  logs            UsageLog[]

  @@unique([email, siteUrl])
  @@index([email])
  @@index([siteUrl])
  @@index([lastActiveAt])
}

// Every single humanization request
model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  siteUrl     String
  inputWords  Int
  outputWords Int
  mode        String   // light, balanced, aggressive
  tone        String?  // professional, casual, academic, friendly
  postId      Int?     // WordPress post ID if from editor
  postTitle   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([siteUrl])
  @@index([createdAt])
  @@index([mode])
}

// Track each WordPress site using the plugin
model Site {
  id            String   @id @default(cuid())
  siteUrl       String   @unique
  siteName      String?
  wpVersion     String?
  pluginVersion String?
  phpVersion    String?
  totalUsers    Int      @default(0)
  totalWords    Int      @default(0)
  totalRequests Int      @default(0)
  firstSeenAt   DateTime @default(now())
  lastActiveAt  DateTime @default(now())

  @@index([lastActiveAt])
}
